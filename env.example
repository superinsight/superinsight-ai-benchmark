# ==============================================
# Benchmark Module Environment Variables
# ==============================================
# Copy this file to .env and fill in your values

# ==============================================
# Gemini (Vertex AI Mode) - REQUIRED
# ==============================================
# Path to GCP credential JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp_credential.json

# GCP Project ID (required for Vertex AI)
GCP_PROJECT_ID=your-gcp-project-id

# GCP Location (optional, default: us-central1)
GCP_LOCATION=us-central1

# Alternative: JSON content directly (for deployment)
# GOOGLE_CERT_JSON={"type":"service_account",...}

# ==============================================
# Nebius (Optional - alternative LLM backend)
# ==============================================
# NEBIUS_API_KEY=your-nebius-api-key
# NEBIUS_API_BASE=https://api.studio.nebius.com/v1

# ==============================================
# LLM Backend Selection
# ==============================================
# Which LLM backend to use: "gemini" or "nebius"
LLM_BACKEND=gemini

# ==============================================
# Model Configuration
# ==============================================
# Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Gemini fallback models (comma-separated, tried in order on failure)
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash

# Nebius model (default: deepseek-ai/DeepSeek-V3)
# NEBIUS_MODEL=deepseek-ai/DeepSeek-V3

# Nebius fallback models
# NEBIUS_FALLBACK_MODELS=deepseek-ai/DeepSeek-V3,Qwen/Qwen3-235B-A22B-Instruct-2507

# ==============================================
# Retry Configuration
# ==============================================
# Max retry attempts per model (default: 3)
LLM_MAX_RETRIES=3

# Initial retry delay in seconds (default: 1.0, uses exponential backoff)
LLM_RETRY_DELAY=1.0

# ==============================================
# Token Limits (Optional)
# ==============================================
# Gemini token limits
GEMINI_MAX_INPUT_TOKENS=1000000
GEMINI_MAX_OUTPUT_TOKENS=8192

# Nebius token limits
# NEBIUS_MAX_INPUT_TOKENS=64000
# NEBIUS_MAX_OUTPUT_TOKENS=8192

# ==============================================
# Benchmark Settings (Optional)
# ==============================================
# Max characters for source text in hallucination check (0 = no limit)
BENCHMARK_MAX_SOURCE_CHARS=0

# Max characters per claim
BENCHMARK_MAX_CLAIM_CHARS=200

# Max characters for source excerpt per claim
BENCHMARK_MAX_SOURCE_EXCERPT_CHARS=3000

# ==============================================
# Completeness Judge Settings (Optional)
# ==============================================
# Max characters for source text in completeness check (0 = no limit)
COMPLETENESS_MAX_SOURCE_CHARS=0

# Max characters for output text in completeness check (0 = no limit)
COMPLETENESS_MAX_OUTPUT_CHARS=0

# ==============================================
# OpenAI (Optional - for GPT models)
# ==============================================
# OPENAI_API_KEY=your-openai-api-key

# ==============================================
# Anthropic (Optional - for Claude models)
# ==============================================
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ==============================================
# Google AI Studio (Optional - for Gemini 3+ preview models)
# ==============================================
# GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-key

# ==============================================
# AWS S3 (Optional - for remote file access)
# ==============================================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

# ==============================================
# Parallel Processing
# ==============================================
# Max concurrent API calls for hallucination check
# Higher values = faster but may hit rate limits
# Recommended: 5-10 for Gemini, 3-5 for Nebius
MAX_WORKERS=5

# ==============================================
# Default Benchmark Settings
# ==============================================
# Deep check mode (enable LLM-based hallucination checking)
DEEP_CHECK=true

# Max claims to verify with LLM judge
MAX_CLAIMS=50

# Claims per API call for hallucination check
BATCH_SIZE=10
